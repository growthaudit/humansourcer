---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonicalPath: string; // e.g. "/" or "/providers/alignerr"
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  // Grace-window ("no longer listed") role pages and non-canonical
  // filter-combination views use this — real content, just not something
  // that should claim a place in search results.
  noindex?: boolean;
}

const { title, description, canonicalPath, jsonLd, noindex = false } = Astro.props;
const canonicalUrl = new URL(canonicalPath, Astro.site);
const jsonLdBlocks = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />
    {noindex && <meta name="robots" content="noindex,follow" />}
    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="preload" href="/fonts/manrope-variable.woff2" as="font" type="font/woff2" crossorigin />

    {jsonLdBlocks.map((block) => (
      <script type="application/ld+json" set:html={JSON.stringify(block)} />
    ))}
  </head>
  <body class="min-h-screen bg-bg font-body text-ink-primary antialiased">
    <header class="border-b border-border">
      <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4">
        <a href="/" class="flex items-center gap-2 font-display text-lg font-semibold tracking-tight text-ink-primary">
          <svg viewBox="0 0 366 366" class="h-5 w-5 flex-none" fill="currentColor" aria-hidden="true">
            <path
              fill-rule="evenodd"
              d="M 93.50 80.00 L 93.50 285.00 L 137.50 285.00 L 138.50 225.00 L 149.50 234.00 L 164.50 240.00 L 182.50 241.00 L 198.50 237.00 L 239.50 285.00 L 272.50 285.00 L 215.50 223.00 L 222.50 216.00 L 259.50 252.00 L 259.50 81.00 L 215.50 80.00 L 213.50 152.00 L 195.50 140.00 L 168.50 137.00 L 152.50 142.00 L 138.50 153.00 L 137.50 80.00 Z M 171.50 151.00 L 181.50 151.00 L 182.50 152.00 L 185.50 152.00 L 186.50 153.00 L 191.50 154.00 L 195.50 156.00 L 198.50 159.00 L 199.50 159.00 L 206.50 166.00 L 206.50 167.00 L 208.50 169.00 L 211.50 175.00 L 212.50 180.00 L 213.50 181.00 L 213.50 187.00 L 214.50 188.00 L 214.50 190.00 L 213.50 191.00 L 213.50 197.00 L 212.50 198.00 L 212.50 201.00 L 206.50 212.00 L 199.50 219.00 L 198.50 219.00 L 196.50 221.00 L 188.50 225.00 L 186.50 225.00 L 185.50 226.00 L 180.50 226.00 L 179.50 227.00 L 167.50 226.00 L 166.50 225.00 L 161.50 224.00 L 154.50 220.00 L 144.50 210.00 L 140.50 202.00 L 139.50 196.00 L 138.50 195.00 L 138.50 183.00 L 139.50 182.00 L 139.50 179.00 L 140.50 178.00 L 141.50 173.00 L 143.50 171.00 L 144.50 168.00 L 147.50 165.00 L 147.50 164.00 L 155.50 157.00 L 163.50 153.00 L 166.50 153.00 L 167.50 152.00 L 170.50 152.00 Z"
            />
          </svg>
          HumanSourcer
        </a>
        <nav class="flex gap-4 text-sm text-ink-secondary">
          <a
            href="/"
            class={`transition-colors duration-200 ease-out ${
              Astro.url.pathname === '/' ||
              (Astro.url.pathname.startsWith('/providers') && !Astro.url.pathname.startsWith('/providers/gig'))
                ? 'font-semibold text-ink-primary'
                : 'hover:text-ink-primary'
            }`}
          >
            Providers
          </a>
          <a
            href="/providers/gig/"
            class={`transition-colors duration-200 ease-out ${
              Astro.url.pathname.startsWith('/providers/gig')
                ? 'font-semibold text-ink-primary'
                : 'hover:text-ink-primary'
            }`}
          >
            Gig
          </a>
          <a
            href="/roles/"
            class={`transition-colors duration-200 ease-out ${
              Astro.url.pathname.startsWith('/roles')
                ? 'font-semibold text-ink-primary'
                : 'hover:text-ink-primary'
            }`}
          >
            Roles
          </a>
          <a
            href="/market-data/"
            class={`transition-colors duration-200 ease-out ${
              Astro.url.pathname.startsWith('/market-data')
                ? 'font-semibold text-ink-primary'
                : 'hover:text-ink-primary'
            }`}
          >
            Market data
          </a>
        </nav>
      </div>
    </header>
    <main class="mx-auto max-w-6xl px-4 py-8">
      <slot />
    </main>
    <footer class="mt-16 border-t border-border">
      <div class="mx-auto max-w-6xl px-4 py-8 text-sm text-ink-tertiary">
        <p>
          HumanSourcer indexes publicly documented worker-facing access points for AI-training
          networks. Every ownership and status claim links to its source. Not affiliated with any
          listed provider.
        </p>
      </div>
    </footer>
  </body>
</html>
