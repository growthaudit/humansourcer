---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonicalPath: string; // e.g. "/" or "/providers/alignerr"
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  // Grace-window ("no longer listed") role pages and non-canonical
  // filter-combination views use this — real content, just not something
  // that should claim a place in search results.
  noindex?: boolean;
}

const { title, description, canonicalPath, jsonLd, noindex = false } = Astro.props;
const canonicalUrl = new URL(canonicalPath, Astro.site);
const jsonLdBlocks = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />
    {noindex && <meta name="robots" content="noindex,follow" />}
    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="preload" href="/fonts/manrope-variable.woff2" as="font" type="font/woff2" crossorigin />

    {jsonLdBlocks.map((block) => (
      <script type="application/ld+json" set:html={JSON.stringify(block)} />
    ))}
  </head>
  <body class="min-h-screen bg-bg font-body text-ink-primary antialiased">
    <header class="border-b border-border">
      <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4">
        <a href="/" class="font-display text-lg font-semibold tracking-tight text-ink-primary">
          HumanSourcer
        </a>
        <nav class="flex gap-4 text-sm text-ink-secondary">
          <a
            href="/"
            class={`transition-colors duration-200 ease-out ${
              Astro.url.pathname === '/' || Astro.url.pathname.startsWith('/providers')
                ? 'font-semibold text-ink-primary'
                : 'hover:text-ink-primary'
            }`}
          >
            Providers
          </a>
          <a
            href="/gig/"
            class={`transition-colors duration-200 ease-out ${
              Astro.url.pathname.startsWith('/gig')
                ? 'font-semibold text-ink-primary'
                : 'hover:text-ink-primary'
            }`}
          >
            Gig
          </a>
          <a
            href="/roles/"
            class={`transition-colors duration-200 ease-out ${
              Astro.url.pathname.startsWith('/roles')
                ? 'font-semibold text-ink-primary'
                : 'hover:text-ink-primary'
            }`}
          >
            Roles
          </a>
        </nav>
      </div>
    </header>
    <main class="mx-auto max-w-6xl px-4 py-8">
      <slot />
    </main>
    <footer class="mt-16 border-t border-border">
      <div class="mx-auto max-w-6xl px-4 py-8 text-sm text-ink-tertiary">
        <p>
          HumanSourcer indexes publicly documented worker-facing access points for AI-training
          networks. Every ownership and status claim links to its source. Not affiliated with any
          listed provider.
        </p>
      </div>
    </footer>
  </body>
</html>
