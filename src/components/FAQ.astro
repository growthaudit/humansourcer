---
// Plain, always-visible Q&A markup — deliberately NOT a JS accordion.
// Crawlers and answer-engine ingestion pipelines don't reliably execute
// client JS to reveal collapsed content; keeping every answer in the
// initial HTML maximizes both traditional crawlability and AEO/GEO
// extractability. FAQPage JSON-LD is built separately in src/lib/jsonld.ts
// from the same `items` array, so visible copy and structured data can
// never disagree.
import type { FAQItem } from '../lib/role-faq';

interface Props {
  items: FAQItem[];
}

const { items } = Astro.props;
---

<div class="mt-10 border-t border-slate-200 pt-6">
  <h2 class="text-sm uppercase tracking-wide text-slate-400">Frequently asked questions</h2>
  <div class="mt-3 space-y-4">
    {items.map((item) => (
      <div>
        <h3 class="font-medium text-slate-800">{item.question}</h3>
        <p class="mt-1 text-sm text-slate-600">{item.answer}</p>
      </div>
    ))}
  </div>
</div>
