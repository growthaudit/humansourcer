---
import Layout from '../../../layouts/Layout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import FAQ from '../../../components/FAQ.astro';
import type { CollectionEntry } from 'astro:content';
import { rolePagePath, roleSlug, type FullRole } from '../../../lib/roles';
import { getEligibleActiveRoles } from '../../../lib/role-rows';
import { breadcrumbListJsonLd, jobPostingJsonLd, faqPageJsonLd } from '../../../lib/jsonld';
import { composeRoleDescription } from '../../../lib/role-description';
import { roleFAQs } from '../../../lib/role-faq';
import {
  taskType,
  locationBucket,
  payBand,
  TASK_TYPE_LABELS,
  LOCATION_BUCKET_LABELS,
  PAY_BAND_LABELS,
} from '../../../lib/role-taxonomy';
import { geographyScope, DOMAIN_TAG_LABELS } from '../../../lib/taxonomy';
import { providerHref } from '../../../lib/provider-url';

type Provider = CollectionEntry<'providers'>['data'];

export async function getStaticPaths() {
  const eligible = await getEligibleActiveRoles();

  return eligible.map(({ role, provider }) => {
    const similarRoles = role.is_active
      ? []
      : eligible
          .filter(
            (r) =>
              r.role.is_active &&
              r.role.id !== role.id &&
              (r.role.provider_slug === role.provider_slug || taskType(r.role) === taskType(role))
          )
          .slice(0, 5)
          .map((r) => r.role);

    return {
      params: {
        provider: role.provider_slug,
        roleSlug: roleSlug(role.title, role.provider_slug, role.source_role_id),
      },
      props: { role, provider, similarRoles },
    };
  });
}

interface Props {
  role: FullRole;
  provider: Provider;
  similarRoles: FullRole[];
}

const { role, provider, similarRoles }: Props = Astro.props;

const path = rolePagePath(role);
const roleUrl = new URL(path, Astro.site).toString();
const providerUrl = new URL(providerHref(provider), Astro.site).toString();

const breadcrumbItems = [
  { name: 'Home', url: new URL('/', Astro.site).toString() },
  { name: 'Roles', url: new URL('/roles/', Astro.site).toString() },
  { name: provider.workerBrand, url: providerUrl },
  { name: role.title, url: roleUrl },
];

// FAQ only for active roles — "how do I apply" etc. don't make sense once a
// role is gone, and grace-window pages deliberately stay minimal (no
// JobPosting either — see jobPostingJsonLd's own is_active gate).
const faqs = role.is_active ? roleFAQs(role, provider) : [];

const jsonLd = role.is_active
  ? [
      breadcrumbListJsonLd(breadcrumbItems),
      jobPostingJsonLd(role, provider, roleUrl),
      faqPageJsonLd(faqs),
    ]
  : [breadcrumbListJsonLd(breadcrumbItems)];

const description = composeRoleDescription(role, provider);
const title = role.is_active
  ? `${role.title} at ${provider.workerBrand} | HumanSourcer`
  : `${role.title} at ${provider.workerBrand} (no longer listed) | HumanSourcer`;

const task = taskType(role);
const location = locationBucket({ location: role.location }, geographyScope(provider.geography));
const pay = payBand(role);

// Direct-answer lead sentence — states the core facts (what/where/pay) in
// one extractable line before any elaboration, the pattern AI Overviews and
// LLM answer engines most reliably lift for a snippet-style answer.
const leadSentence = [
  `${role.title} is an open role at ${provider.workerBrand}`,
  location === 'remote' ? ', available remotely' : role.location ? `, located in ${role.location}` : '',
  pay !== 'unspecified' && role.pay_text ? `, with pay listed as ${role.pay_text}` : '',
  '.',
].join('');
---

<Layout title={title} description={description} canonicalPath={path} jsonLd={jsonLd} noindex={!role.is_active}>
  <Breadcrumbs items={breadcrumbItems} />

  {!role.is_active && (
    <div class="mb-6 rounded-lg border border-amber-900 bg-amber-950 p-4 text-sm text-amber-200">
      This role is no longer listed by {provider.workerBrand}. It last appeared active on{' '}
      {new Date(role.last_seen_at).toISOString().slice(0, 10)}.
    </div>
  )}

  <div class="text-sm uppercase tracking-wide text-ink-tertiary">{provider.workerBrand}</div>
  <h1 class="mt-1 text-3xl font-bold tracking-tight">{role.title}</h1>

  <div class="mt-4 flex flex-wrap gap-2 text-xs">
    <a href={`/roles/task/${task}/`} class="rounded-full bg-surface-raised px-3 py-1 text-ink-secondary transition-colors duration-200 ease-out hover:bg-border">
      {TASK_TYPE_LABELS[task]}
    </a>
    <a href={`/roles/company/${provider.slug}/`} class="rounded-full bg-surface-raised px-3 py-1 text-ink-secondary transition-colors duration-200 ease-out hover:bg-border">
      {provider.workerBrand}
    </a>
    {provider.domainTags.map((tag) => (
      <a href={`/roles/domain/${tag}/`} class="rounded-full bg-surface-raised px-3 py-1 text-ink-secondary transition-colors duration-200 ease-out hover:bg-border">
        {DOMAIN_TAG_LABELS[tag] ?? tag}
      </a>
    ))}
    <span class="rounded-full bg-surface-raised px-3 py-1 text-ink-secondary">{LOCATION_BUCKET_LABELS[location]}</span>
    {pay !== 'unspecified' && (
      <span class="rounded-full bg-surface-raised px-3 py-1 text-ink-secondary">{PAY_BAND_LABELS[pay]}</span>
    )}
  </div>

  {role.is_active && (
    <p class="mt-4 max-w-2xl font-medium text-ink-primary">{leadSentence}</p>
  )}

  <div class="mt-6 max-w-2xl text-ink-secondary">
    <h2 class="text-sm uppercase tracking-wide text-ink-tertiary">About this role</h2>
    <p class="mt-2">{description}</p>
  </div>

  {role.pay_text && (
    <div class="mt-6">
      <h2 class="text-sm uppercase tracking-wide text-ink-tertiary">Pay</h2>
      <p class="mt-1 text-ink-secondary">{role.pay_text}</p>
    </div>
  )}

  {role.is_active ? (
    <div class="mt-8">
      <a
        href={role.apply_url}
        rel="nofollow sponsored"
        class="inline-block rounded-md bg-accent px-5 py-2.5 text-sm font-semibold text-accent-ink transition-colors duration-200 ease-out hover:bg-accent-hover"
      >
        Apply at {provider.workerBrand} &rarr;
      </a>
    </div>
  ) : (
    <div class="mt-8">
      <a href={providerUrl} class="inline-block rounded-md bg-accent px-5 py-2.5 text-sm font-semibold text-accent-ink transition-colors duration-200 ease-out hover:bg-accent-hover">
        View {provider.workerBrand}&rsquo;s current open roles &rarr;
      </a>
    </div>
  )}

  <div class="mt-10 border-t border-border pt-6">
    <h2 class="text-sm uppercase tracking-wide text-ink-tertiary">About {provider.workerBrand}</h2>
    <p class="mt-2 max-w-2xl text-ink-secondary">
      {provider.workerBrand}'s connection to {provider.parentGroup}: {provider.relationship}. {provider.typicalWork}
    </p>
    <p class="mt-2 text-sm text-ink-secondary">
      Ownership confidence: {provider.ownershipConfidence}.{' '}
      <a href={providerUrl} class="underline">See the full network profile &rarr;</a>
    </p>
  </div>

  {similarRoles.length > 0 && (
    <div class="mt-10 border-t border-border pt-6">
      <h2 class="text-sm uppercase tracking-wide text-ink-tertiary">Similar open roles</h2>
      <div class="mt-3 space-y-2">
        {similarRoles.map((r) => (
          <a href={rolePagePath(r)} class="block rounded-lg border border-border p-3 text-sm transition-colors duration-200 ease-out hover:border-border-strong">
            <span class="font-medium text-ink-primary">{r.title}</span>
            <span class="text-ink-secondary"> &middot; {r.provider_slug}</span>
          </a>
        ))}
      </div>
    </div>
  )}

  {faqs.length > 0 && <FAQ items={faqs} />}
</Layout>
