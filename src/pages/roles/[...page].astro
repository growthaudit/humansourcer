---
import type { GetStaticPathsOptions, Page } from 'astro';
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import RolesFilter from '../../components/RolesFilter';
import { getEligibleActiveRoles, toRoleRow, type RoleWithProvider } from '../../lib/role-rows';
import { itemListJsonLd, breadcrumbListJsonLd } from '../../lib/jsonld';

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const PAGE_SIZE = 24;
  const eligible = await getEligibleActiveRoles();
  const sorted = eligible
    .slice()
    .sort((a, b) => new Date(b.role.last_seen_at).getTime() - new Date(a.role.last_seen_at).getTime());
  return paginate(sorted, { pageSize: PAGE_SIZE });
}

interface Props {
  page: Page<RoleWithProvider>;
}

const { page } = Astro.props;
const rows = page.data.map(({ role, provider }) => toRoleRow(role, provider));

const canonicalPath = page.currentPage === 1 ? '/roles/' : `/roles/${page.currentPage}/`;
const pageUrl = new URL(canonicalPath, Astro.site).toString();

const breadcrumbItems = [
  { name: 'Home', url: new URL('/', Astro.site).toString() },
  { name: 'Roles', url: new URL('/roles/', Astro.site).toString() },
];

const jsonLd = [
  breadcrumbListJsonLd(breadcrumbItems),
  itemListJsonLd(rows.map((r) => ({ name: r.title, url: new URL(r.href, Astro.site).toString() })), pageUrl),
];

const title =
  page.currentPage === 1
    ? 'Open roles across AI-training expert networks | HumanSourcer'
    : `Open roles across AI-training expert networks (page ${page.currentPage}) | HumanSourcer`;
const description = `Browse ${page.total} open roles across HumanSourcer's expert AI-training networks, filterable by domain, task type, pay, location, and company.`;
---

<Layout title={title} description={description} canonicalPath={canonicalPath} jsonLd={jsonLd}>
  <Breadcrumbs items={breadcrumbItems} />
  <h1 class="text-3xl font-bold tracking-tight">Open roles</h1>
  <p class="mt-2 max-w-2xl text-slate-600">
    {page.total} open roles scraped daily across HumanSourcer's expert-tier AI-training networks.
  </p>

  <div class="mt-8">
    <RolesFilter roles={rows} client:load />
  </div>

  {page.lastPage > 1 && (
    <nav class="mt-8 flex items-center justify-between text-sm" aria-label="Pagination">
      {page.url.prev ? (
        <a href={page.url.prev} class="text-slate-600 hover:text-slate-900">&larr; Newer</a>
      ) : <span />}
      <span class="text-slate-400">Page {page.currentPage} of {page.lastPage}</span>
      {page.url.next ? (
        <a href={page.url.next} class="text-slate-600 hover:text-slate-900">Older &rarr;</a>
      ) : <span />}
    </nav>
  )}
</Layout>
