---
import type { GetStaticPathsOptions, Page } from 'astro';
import Layout from '../../../../layouts/Layout.astro';
import Breadcrumbs from '../../../../components/Breadcrumbs.astro';
import RolesFilter from '../../../../components/RolesFilter';
import FAQ from '../../../../components/FAQ.astro';
import { getEligibleActiveRoles, groupByDomain, toRoleRow, type RoleWithProvider } from '../../../../lib/role-rows';
import { itemListJsonLd, breadcrumbListJsonLd, faqPageJsonLd } from '../../../../lib/jsonld';
import { DOMAIN_TAG_LABELS } from '../../../../lib/taxonomy';
import { computeHubStats, domainHubFAQs, DOMAIN_TAG_DESCRIPTIONS, type HubStats } from '../../../../lib/role-faq';

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const PAGE_SIZE = 24;
  const eligible = await getEligibleActiveRoles();
  const byDomain = groupByDomain(eligible);
  return [...byDomain.entries()].flatMap(([tag, items]) =>
    paginate(items, { params: { tag }, pageSize: PAGE_SIZE, props: { stats: computeHubStats(items) } })
  );
}

interface Props {
  page: Page<RoleWithProvider>;
  stats: HubStats;
}

const { tag } = Astro.params;
const { page, stats } = Astro.props;
const rows = page.data.map(({ role, provider }) => toRoleRow(role, provider));
const label = (DOMAIN_TAG_LABELS[tag as string] ?? tag) as string;
const blurb = DOMAIN_TAG_DESCRIPTIONS[tag as string] ?? `AI-training work in the ${label} domain.`;
const faqs = domainHubFAQs(tag as string, stats);

const canonicalPath = page.currentPage === 1 ? `/roles/domain/${tag}/` : `/roles/domain/${tag}/${page.currentPage}/`;
const pageUrl = new URL(canonicalPath, Astro.site).toString();

const breadcrumbItems = [
  { name: 'Home', url: new URL('/', Astro.site).toString() },
  { name: 'Roles', url: new URL('/roles/', Astro.site).toString() },
  { name: label, url: new URL(`/roles/domain/${tag}/`, Astro.site).toString() },
];

const jsonLd = [
  breadcrumbListJsonLd(breadcrumbItems),
  itemListJsonLd(rows.map((r) => ({ name: r.title, url: new URL(r.href, Astro.site).toString() })), pageUrl),
  faqPageJsonLd(faqs),
];

const title = `${label} roles across AI-training networks | HumanSourcer`;
const description = `${stats.totalRoles} open ${label.toLowerCase()} roles across HumanSourcer's expert AI-training networks. ${blurb}`;
---

<Layout title={title} description={description} canonicalPath={canonicalPath} jsonLd={jsonLd}>
  <Breadcrumbs items={breadcrumbItems} />
  <h1 class="text-3xl font-bold tracking-tight">{label} roles</h1>
  <p class="mt-2 max-w-2xl font-medium text-slate-800">
    {stats.totalRoles} open {label.toLowerCase()} roles are currently listed across {stats.companies.length} AI-training networks.
  </p>
  <p class="mt-2 max-w-2xl text-slate-600">{blurb}</p>

  <div class="mt-8">
    <RolesFilter roles={rows} client:load />
  </div>

  {page.lastPage > 1 && (
    <nav class="mt-8 flex items-center justify-between text-sm" aria-label="Pagination">
      {page.url.prev ? (
        <a href={page.url.prev} class="text-slate-600 hover:text-slate-900">&larr; Newer</a>
      ) : <span />}
      <span class="text-slate-400">Page {page.currentPage} of {page.lastPage}</span>
      {page.url.next ? (
        <a href={page.url.next} class="text-slate-600 hover:text-slate-900">Older &rarr;</a>
      ) : <span />}
    </nav>
  )}

  <FAQ items={faqs} />
</Layout>
