---
import type { GetStaticPathsOptions, Page } from 'astro';
import Layout from '../../../../layouts/Layout.astro';
import Breadcrumbs from '../../../../components/Breadcrumbs.astro';
import RolesFilter from '../../../../components/RolesFilter';
import FAQ from '../../../../components/FAQ.astro';
import { getEligibleActiveRoles, groupByLocationBucket, toRoleRow, type RoleWithProvider } from '../../../../lib/role-rows';
import { itemListJsonLd, breadcrumbListJsonLd, faqPageJsonLd } from '../../../../lib/jsonld';
import { LOCATION_BUCKET_LABELS, type LocationBucket } from '../../../../lib/role-taxonomy';
import { computeHubStats, locationHubFAQs, LOCATION_BUCKET_DESCRIPTIONS, type HubStats } from '../../../../lib/role-faq';

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const PAGE_SIZE = 24;
  const eligible = await getEligibleActiveRoles();
  const byLocation = groupByLocationBucket(eligible);
  // "unspecified" isn't a real location facet (it means the source
  // disclosed nothing) — generating a hub for it would be exactly the
  // thin/no-search-intent content this section is designed to avoid.
  byLocation.delete('unspecified');
  return [...byLocation.entries()].flatMap(([bucket, items]) =>
    paginate(items, { params: { bucket }, pageSize: PAGE_SIZE, props: { stats: computeHubStats(items) } })
  );
}

interface Props {
  page: Page<RoleWithProvider>;
  stats: HubStats;
}

const { bucket } = Astro.params;
const { page, stats } = Astro.props;
const bucketValue = bucket as LocationBucket;
const rows = page.data.map(({ role, provider }) => toRoleRow(role, provider));
const label = LOCATION_BUCKET_LABELS[bucketValue] ?? bucket;
const blurb = LOCATION_BUCKET_DESCRIPTIONS[bucketValue] ?? `AI-training roles listed as ${String(label).toLowerCase()}.`;
const faqs = locationHubFAQs(bucketValue, stats);

const canonicalPath = page.currentPage === 1 ? `/roles/location/${bucket}/` : `/roles/location/${bucket}/${page.currentPage}/`;
const pageUrl = new URL(canonicalPath, Astro.site).toString();

const breadcrumbItems = [
  { name: 'Home', url: new URL('/', Astro.site).toString() },
  { name: 'Roles', url: new URL('/roles/', Astro.site).toString() },
  { name: label as string, url: new URL(`/roles/location/${bucket}/`, Astro.site).toString() },
];

const jsonLd = [
  breadcrumbListJsonLd(breadcrumbItems),
  itemListJsonLd(rows.map((r) => ({ name: r.title, url: new URL(r.href, Astro.site).toString() })), pageUrl),
  faqPageJsonLd(faqs),
];

const title = `${label} AI-training roles | HumanSourcer`;
const description = `${stats.totalRoles} open ${String(label).toLowerCase()} roles across HumanSourcer's expert AI-training networks. ${blurb}`;
---

<Layout title={title} description={description} canonicalPath={canonicalPath} jsonLd={jsonLd}>
  <Breadcrumbs items={breadcrumbItems} />
  <h1 class="text-3xl font-bold tracking-tight">{label} roles</h1>
  <p class="mt-2 max-w-2xl font-medium text-ink-primary">
    {stats.totalRoles} open {String(label).toLowerCase()} roles are currently listed across {stats.companies.length} AI-training networks.
  </p>
  <p class="mt-2 max-w-2xl text-ink-secondary">{blurb}</p>

  <div class="mt-8">
    <RolesFilter roles={rows} client:load />
  </div>

  {page.lastPage > 1 && (
    <nav class="mt-8 flex items-center justify-between text-sm" aria-label="Pagination">
      {page.url.prev ? (
        <a href={page.url.prev} class="text-ink-secondary transition-colors duration-200 ease-out hover:text-ink-primary">&larr; Newer</a>
      ) : <span />}
      <span class="text-ink-tertiary">Page {page.currentPage} of {page.lastPage}</span>
      {page.url.next ? (
        <a href={page.url.next} class="text-ink-secondary transition-colors duration-200 ease-out hover:text-ink-primary">Older &rarr;</a>
      ) : <span />}
    </nav>
  )}

  <FAQ items={faqs} />
</Layout>
