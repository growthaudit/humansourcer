---
import Layout from '../layouts/Layout.astro';
import ProviderFilter from '../components/ProviderFilter';
import type { ProviderRow } from '../components/ProviderFilter';
import { getCollection } from 'astro:content';
import { accessModelCategory, geographyScope } from '../lib/taxonomy';
import { providerHref } from '../lib/provider-url';
import { itemListJsonLd } from '../lib/jsonld';

const allProviders = (await getCollection('providers')).sort((a, b) =>
  a.data.workerBrand.localeCompare(b.data.workerBrand)
);

const rows: ProviderRow[] = allProviders.map((p) => ({
  slug: p.data.slug,
  href: providerHref(p.data),
  workerBrand: p.data.workerBrand,
  parentGroup: p.data.parentGroup,
  typicalWork: p.data.typicalWork,
  domainTags: p.data.domainTags,
  audienceTiers: p.data.audienceTiers,
  accessModelCategory: accessModelCategory(p.data.accessModel),
  geographyScope: geographyScope(p.data.geography),
}));

const expertCount = allProviders.filter((p) => p.data.audienceTiers.includes('expert')).length;
const gigCount = allProviders.filter((p) => p.data.audienceTiers.includes('gig')).length;
const restrictedCount = allProviders.filter((p) => p.data.audienceTiers.includes('restricted')).length;

const listUrl = new URL('/', Astro.site).toString();
const jsonLd = itemListJsonLd(
  allProviders.map((p) => ({
    name: p.data.workerBrand,
    url: new URL(providerHref(p.data), Astro.site).toString(),
  })),
  listUrl
);

const title = 'AI-Training & Data-Annotation Provider Directory | HumanSourcer';
const description = `Compare ${allProviders.length} AI-training and data-annotation providers — expert networks, gig/task platforms, and managed workforces like Mercor, Alignerr, DataAnnotation, and Outlier — domain focus, access model, geography, and ownership, each with a cited source.`;
---

<Layout title={title} description={description} canonicalPath="/" jsonLd={jsonLd}>
  <h1 class="text-3xl font-bold tracking-tight">AI-training &amp; data-annotation providers</h1>
  <p class="mt-2 max-w-2xl text-ink-secondary">
    {allProviders.length} providers across three tiers: {expertCount}{' '}
    <a href="/providers/experts/" class="underline">expert networks</a> that recruit domain
    specialists (lawyers, physicians, engineers), {gigCount}{' '}
    <a href="/providers/gig/" class="underline">gig/task platforms</a> open to anyone, and {restrictedCount}{' '}
    <a href="/providers/restricted/" class="underline">managed workforces</a> with no public
    self-serve worker portal. Filter by tier, domain, company, access model, and geography below —
    every ownership and status claim links to its public source.
  </p>
  <p class="mt-2 max-w-2xl text-ink-secondary">
    Looking for open positions instead? <a href="/roles/" class="underline">Browse all open roles</a>,
    filterable by domain, task type, pay, location, and company.
  </p>
  <p class="mt-2 max-w-2xl text-ink-secondary">
    New here? See the <a href="/best-ai-training-platforms/" class="underline">best AI training platforms</a>{' '}
    ranked by ownership and open roles, or platforms with{' '}
    <a href="/no-experience-required/" class="underline">no experience required</a> to apply.
    There's also a list of <a href="/other-ai-job-boards/" class="underline">other independent job boards</a>.
  </p>

  <div class="mt-8">
    <ProviderFilter providers={rows} client:load />
  </div>
</Layout>
