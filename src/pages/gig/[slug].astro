---
import Layout from '../../layouts/Layout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { organizationJsonLd, breadcrumbListJsonLd } from '../../lib/jsonld';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ProviderDetail from '../../components/ProviderDetail.astro';

export async function getStaticPaths() {
  const all = await getCollection('providers');
  const gigs = all.filter((p) => p.data.audienceTier === 'gig');
  return gigs.map((provider) => ({
    params: { slug: provider.data.slug },
    props: { provider },
  }));
}

interface Props {
  provider: CollectionEntry<'providers'>;
}

const { provider }: Props = Astro.props;
const p = provider.data;

const profileUrl = new URL(`/gig/${p.slug}`, Astro.site).toString();
const breadcrumbItems = [
  { name: 'Home', url: new URL('/', Astro.site).toString() },
  { name: 'Gig platforms', url: new URL('/gig/', Astro.site).toString() },
  { name: p.workerBrand, url: profileUrl },
];
const jsonLd = [organizationJsonLd(p, profileUrl), breadcrumbListJsonLd(breadcrumbItems)];

const title = `Is ${p.workerBrand} Legit? Pay & Ownership Review | HumanSourcer`;
const description = `Is ${p.workerBrand} legit? ${p.relationship} (ownership confidence: ${p.ownershipConfidence.toLowerCase()}). ${p.typicalWork}.`;
---

<Layout title={title} description={description} canonicalPath={`/gig/${p.slug}`} jsonLd={jsonLd}>
  <Breadcrumbs items={breadcrumbItems} />
  <ProviderDetail
    provider={provider}
    providerRoles={{ roles: [], totalCount: 0 }}
    backHref="/gig/"
    backLabel="All gig platforms"
    ctaLabel={`Visit ${p.workerBrand}`}
    ctaRel="nofollow sponsored"
    showRoles={false}
  />
</Layout>
