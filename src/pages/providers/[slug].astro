---
import Layout from '../../layouts/Layout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { organizationJsonLd, breadcrumbListJsonLd } from '../../lib/jsonld';
import { getActiveRolesByProvider, type ProviderRoles } from '../../lib/roles';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ProviderDetail from '../../components/ProviderDetail.astro';

export async function getStaticPaths() {
  const all = await getCollection('providers');
  const experts = all.filter((p) => p.data.audienceTiers[0] === 'expert');
  const rolesByProvider = await getActiveRolesByProvider();
  return experts.map((provider) => ({
    params: { slug: provider.data.slug },
    props: {
      provider,
      providerRoles: rolesByProvider.get(provider.data.slug) ?? { roles: [], totalCount: 0 },
    },
  }));
}

interface Props {
  provider: CollectionEntry<'providers'>;
  providerRoles: ProviderRoles;
}

const { provider, providerRoles }: Props = Astro.props;
const p = provider.data;

const profileUrl = new URL(`/providers/${p.slug}`, Astro.site).toString();
const breadcrumbItems = [
  { name: 'Home', url: new URL('/', Astro.site).toString() },
  { name: 'Providers', url: new URL('/', Astro.site).toString() },
  { name: p.workerBrand, url: profileUrl },
];
const jsonLd = [organizationJsonLd(p, profileUrl), breadcrumbListJsonLd(breadcrumbItems)];

const title = `Is ${p.workerBrand} Legit? Pay & Ownership Review | HumanSourcer`;
const description = `Is ${p.workerBrand} legit? ${p.relationship} (ownership confidence: ${p.ownershipConfidence.toLowerCase()}). ${p.typicalWork}.`;
---

<Layout title={title} description={description} canonicalPath={`/providers/${p.slug}`} jsonLd={jsonLd}>
  <Breadcrumbs items={breadcrumbItems} />
  <ProviderDetail
    provider={provider}
    providerRoles={providerRoles}
    backHref="/"
    backLabel="All expert networks"
    ctaLabel={`Visit ${p.workerBrand}`}
    ctaRel="nofollow sponsored"
    showRoles={true}
  />
</Layout>
